{
  "addons": {
    "mev-boost": {
      "enable": false,
      "endpoint": "http://127.0.0.1:18550"
    },
    "ssv-node": {
      "dataDir": "/var/mnt/addons/ssv",
      "privateKeyFile": "/var/mnt/addons/ssv/ssv_operator_key",
      "privateKeyPasswordFile": "/var/mnt/addons/ssv/password"
    }
  },
  "consensus": {
    "lighthouse": {
      "dataDir": "/mnt/ethereum/lighthouse",
      "enable": true,
      "endpoint": "http://127.0.0.1:5052",
      "execEndpoint": "http://127.0.0.1:8551",
      "jwtSecretFile": "/mnt/ethereum/secrets/jwt.hex",
      "slasher": {
        "enable": false,
        "historyLength": 4096,
        "maxDatabaseSize": 256
      }
    },
    "nimbus": {
      "dataDir": "/var/mnt/nimbus",
      "enable": false,
      "endpoint": "http://127.0.0.1:5052",
      "execEndpoint": "http://127.0.0.1:8551"
    },
    "prysm": {
      "dataDir": "/var/mnt/prysm",
      "enable": false,
      "endpoint": "http://127.0.0.1:3500",
      "execEndpoint": "http://127.0.0.1:8551",
      "slasher": {
        "enable": false
      }
    },
    "teku": {
      "dataDir": "/var/mnt/teku",
      "enable": false,
      "endpoint": "http://127.0.0.1:5051",
      "execEndpoint": "http://127.0.0.1:8551"
    }
  },
  "execution": {
    "besu": {
      "dataDir": "/var/mnt/besu",
      "enable": false,
      "endpoint": "http://127.0.0.1:8551"
    },
    "erigon": {
      "dataDir": "/mnt/ethereum/erigon",
      "enable": true,
      "endpoint": "http://127.0.0.1:8551",
      "jwtSecretFile": "/mnt/ethereum/secrets/jwt.hex"
    },
    "geth": {
      "dataDir": "/var/mnt/geth",
      "enable": false,
      "endpoint": "http://127.0.0.1:8551"
    },
    "nethermind": {
      "dataDir": "/var/mnt/nethermind",
      "enable": false,
      "endpoint": "http://127.0.0.1:8551"
    }
  },
  "localization": {
    "hostname": "homestakeros-test",
    "timezone": "Europe/Helsinki"
  },
  "mounts": {
    "ethereum": {
      "description": "mainnet",
      "enable": true,
      "options": "noatime",
      "type": "ext4",
      "wantedBy": [
        "multi-user.target"
      ],
      "what": "/dev/disk/by-label/homestaker",
      "where": "/mnt/ethereum"
    }
  },
  "ssh": {
    "authorizedKeys": [
      "sk-ssh-ed25519@openssh.com AAAAGnNrLXNzaC1lZDI1NTE5QG9wZW5zc2guY29tAAAAIOdsfK46X5IhxxEy81am6A8YnHo2rcF2qZ75cHOKG7ToAAAACHNzaDprYXJp ssh:kari"
    ],
    "privateKeyFile": "/mnt/ethereum/secrets/ssh/id_ed25519"
  },
  "vpn": {
    "wireguard": {
      "configFile": "/mnt/ethereum/secrets/wg0.conf",
      "enable": true
    }
  }
}